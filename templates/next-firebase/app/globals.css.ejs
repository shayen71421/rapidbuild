<% if (["tailwind", "shadcn"].includes(config.styling)) { %>@tailwind base;
@tailwind components;
@tailwind utilities;
<% } %>
:root {
  color-scheme: light;
  background: #fbfbf8;
  color: #141414;
}

.dark {
  color-scheme: dark;
  background: #111827;
  color: #f9fafb;
}

body {
  min-height: 100vh;
  margin: 0;
  font-family:
    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
    sans-serif;
}

button,
input {
  font: inherit;
}
